# Token from @BotFather
BOT_TOKEN=

# Optional: SURVEY_PATH=data/survey.json
# Optional: SUBMISSIONS_PATH=data/submissions.jsonl

# Web admin (python -m bot.admin_main or python -m bot.run_all)
